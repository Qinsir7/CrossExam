# Seller-only settings for the CrossExam x402 ASP. Never commit .env.local.
CROSSEXAM_PORT=4022
CROSSEXAM_PUBLIC_URL=https://your-crossexam-domain
# Browser origins permitted to call this API. Keep this explicit in production.
CROSSEXAM_ALLOWED_ORIGINS=https://your-frontend-domain
CROSSEXAM_PAY_TO=0xYourXLayerReceivingAddress
CROSSEXAM_X402_PRICE_USD=0.02
# Transaction Preflight is separately priced so its real external-evidence
# economics can evolve without changing the legacy ASP endpoint.
CROSSEXAM_TRANSACTION_PREFLIGHT_PRICE_USD=0.02
# Passive Agent Trust Check price. PAID_CALL remains disabled until a dedicated
# recipient-bound procurement policy is configured.
CROSSEXAM_ASP_TRUST_PRICE_USD=0.02
# Deep Cross-Examination is a durable multi-source workflow. The quoted price
# is raised automatically if a configured provider budget would violate margin.
CROSSEXAM_DEEP_REVIEW_PRICE_USD=0.20
# Server-only model used by POST /api/v1/reviews. Never expose this key through
# a VITE_ variable or put it in Vercel's browser environment.
CROSSEXAM_DEEPSEEK_API_KEY=
CROSSEXAM_DEEPSEEK_BASE_URL=https://api.deepseek.com
CROSSEXAM_DEEPSEEK_MODEL=deepseek-v4-pro
# Optional server-only authority-domain search for Legal and source-bound
# claims. Search results are post-filtered against CrossExam's official-domain
# allowlist and never become verification merely because the API ranked them.
CROSSEXAM_TAVILY_API_KEY=
# Full external reviews have a distinct price floor from inexpensive completed-
# dispatch aggregation. Higher-cost jobs are quoted upward automatically.
CROSSEXAM_REVIEW_AUTHORIZATION_PRICE_USD=2.00
# Every immutable job quote covers its external evidence budget while retaining
# at least this gross-margin fraction; the floor above is never reduced.
CROSSEXAM_REVIEW_MIN_GROSS_MARGIN=0.40
# Keep true in production: the SDK verifies supported payment kinds at startup.
CROSSEXAM_X402_SYNC=true
# 32-byte EVM private key used only to attest issued assurance records.
# Required whenever CROSSEXAM_X402_SYNC=true. Never expose it to a browser.
CROSSEXAM_SERVICE_SIGNING_KEY=
# Reviewer-id to signing-wallet registry; required only for /network-aggregate.
# Server-owned reviewer/source identity, capability and wallet registry. Do not
# use caller-supplied metadata for any verified assurance status. A source with
# PAID_EVIDENCE_V1 requires responseAdapter plus paymentRecipient. It may only
# yield PROCUREMENT_VERIFIED, never NETWORK_VERIFIED.
CROSSEXAM_REVIEWER_REGISTRY=[]
# Optional buyer key for paid downstream x402 sources. Enabling it
# requires an explicit per-scope atomic-token cap and an allowlist of X Layer
# token contract addresses. It is never read by Vite or the web app. The
# API's embedded worker and the optional separate worker both use the OKX
# credentials below for authenticated market evidence.
CROSSEXAM_PROCUREMENT_SIGNING_KEY=
CROSSEXAM_PROCUREMENT_MAX_PER_SCOPE_ATOMIC=
CROSSEXAM_PROCUREMENT_ALLOWED_ASSETS=
# Worker safety controls. A failed call backs off exponentially (capped at one
# hour); a process-crashed dispatch becomes retryable after the lease expires.
CROSSEXAM_PROCUREMENT_WORKER_POLL_MS=5000
CROSSEXAM_PROCUREMENT_RETRY_BASE_MS=30000
CROSSEXAM_PROCUREMENT_DISPATCH_TIMEOUT_MS=300000
CROSSEXAM_PROCUREMENT_MAX_ATTEMPTS=5
# Outcome-authority ID to signing wallet; required only for /outcomes ingestion.
CROSSEXAM_OUTCOME_AUTHORITY_WALLETS={}
# Executor ID to wallet registry for signed execution receipts.
CROSSEXAM_EXECUTOR_WALLETS={}
# Local durable store; use a persistent mounted volume in deployment.
CROSSEXAM_DATA_DIR=.crossexam-data
# Optional shared production store. When set, PostgreSQL replaces local files
# for records, access grants, outcomes, and paid-request idempotency mappings.
CROSSEXAM_DATABASE_URL=
# Seconds a returned record read token remains valid (default: 30 days).
CROSSEXAM_RECORD_ACCESS_TTL_SECONDS=2592000
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
